// P4-A — Internal Secure Case Management data model (Akanil employees only).
// Normalized PostgreSQL schema. No external accounts, no uploads, no
// external notifications. Public controlled taxonomies (request types,
// platform / value-chain / Forum ids) are stored as validated strings —
// never redefined here (validation lives in lib/internal/taxonomy.ts).

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

