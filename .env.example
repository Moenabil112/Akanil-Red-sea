# =====================================================================
# P4-A — Internal Secure Case Management (Akanil employees only)
# Placeholders only. NEVER commit real credentials, secrets or URLs.
# Copy to .env for local development (.env is git-ignored).
# =====================================================================

# --- Public site (unchanged; optional) -------------------------------
# Production domain for canonical/OG metadata and sitemap. Leave unset
# for root-relative output. Not required for the public build.
# NEXT_PUBLIC_SITE_URL=

# --- Internal system feature flag ------------------------------------
# The internal application is OFF unless this is exactly "true".
# When unset or anything else, internal routes fail closed and the
# public build never touches the database.
P4_INTERNAL_ENABLED=false

# --- P4-B/P4-C operating mode (server-enforced) ----------------------
# disabled | validation | pilot | limited_internal. Fails closed to
# "disabled" when the internal flag is off or this is absent/invalid.
# There is no "production" mode. Never changed from the browser.
# P4-C: limited_internal additionally requires an ACTIVE, human-approved
# LimitedOperationsAuthorization (the env value alone never authorizes it).
P4_OPERATION_MODE=disabled

# Pilot emergency stop. When exactly "true", all pilot access is blocked,
# internal mutations are disabled and sessions are rejected; the public
# Gateway is unaffected.
P4_PILOT_SUSPENDED=false

# Conservative pilot-access / review / step-up durations.
P4_PILOT_ACCESS_MAX_DAYS=30
P4_ACCESS_REVIEW_DAYS=30
P4_STEPUP_WINDOW_MINUTES=15

# Structured-logger level (debug|info|warn|error). Protected values are
# always redacted regardless of level.
# P4_LOG_LEVEL=info

# --- Database (local development only; use Docker Compose or a local
#     PostgreSQL). No cloud/hosted database in this task. ------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL=postgresql://akanil_p4:REPLACE_WITH_LOCAL_DEV_PASSWORD@localhost:5432/akanil_p4_dev?schema=public
# Separate database used by integration tests (wiped between runs).
DATABASE_URL_TEST=postgresql://akanil_p4:REPLACE_WITH_LOCAL_DEV_PASSWORD@localhost:5432/akanil_p4_test?schema=public

# --- Session / authentication secret ---------------------------------
# Generate locally, e.g. `openssl rand -base64 48`. Never commit a real
# value. At least 32 bytes of entropy.
AUTH_SECRET=REPLACE_WITH_LOCAL_RANDOM_SECRET_AT_LEAST_32_BYTES

# --- Session and lockout controls (configurable) ---------------------
P4_SESSION_MAX_AGE_MINUTES=480
P4_SESSION_IDLE_TIMEOUT_MINUTES=60
P4_LOGIN_LOCK_MINUTES=15
P4_LOGIN_MAX_FAILURES=5

# --- Local-only development-user provisioning ------------------------
# Only honoured when P4_ALLOW_DEV_USER=true AND explicit credentials are
# supplied to the create-user script. Never seed a known password.
# P4_ALLOW_DEV_USER=false
