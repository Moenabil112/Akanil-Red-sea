{
  "name": "akanil-institutional-window",
  "version": "1.0.0",
  "private": true,
  "description": "Akanil Morocco–Red Sea Economic Gateway — trilingual institutional introduction window",
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/prisma-generate-build.mjs",
    "build": "next build",
    "start": "next start",
    "db:generate:build": "node scripts/prisma-generate-build.mjs",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:test": "tsx scripts/internal/migrate-test.ts",
    "db:seed:roles": "tsx scripts/internal/seed-roles.ts",
    "db:studio": "prisma studio",
    "internal:user:create": "tsx scripts/internal/create-user.ts",
    "internal:user:disable": "tsx scripts/internal/disable-user.ts",
    "internal:user:reset-password": "tsx scripts/internal/reset-password.ts",
    "internal:audit:verify": "tsx scripts/internal/audit-verify.ts",
    "internal:audit:backfill": "tsx scripts/internal/audit-backfill.ts",
    "internal:audit:test": "vitest run tests/p4b-audit-integrity.test.ts",
    "internal:sessions:cleanup": "tsx scripts/internal/sessions-cleanup.ts",
    "internal:backup:smoke": "bash scripts/internal/backup-restore-smoke.sh",
    "internal:restore:verify": "bash scripts/internal/backup-verify.sh"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.19.3",
    "next": "^15.5.0",
    "prisma": "^6.19.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.5.0",
    "jsdom": "^26.1.0",
    "tsx": "^4.23.1",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
